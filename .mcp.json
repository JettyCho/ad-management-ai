{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--user-data-dir", ".playwright-mcp-profile"]
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp"
    },
    "confluence": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp",
      "headersHelper": "python3 -c \"token=open('.env').read().split('GITHUB_TOKEN=')[1].split('\\n')[0].strip(); print('{\\\"Authorization\\\": \\\"Bearer ' + token + '\\\"}')\""
    },
    "datadog": {
      "type": "http",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp"
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "google_workspace": {
      "command": "bash",
      "args": ["-c", "set -a; source .env; set +a; uvx workspace-mcp --tool-tier core"]
    },
    "salesforce": {
      "command": "npx",
      "args": ["-y", "@salesforce/mcp", "--orgs", "ALLOW_ALL_ORGS", "--toolsets", "core,orgs,metadata,data,users"]
    },
    "datahub": {
      "command": "bash",
      "args": ["-c", "set -a; source .env; set +a; uvx mcp-server-datahub@latest"]
    },
    "duckdb": {
      "command": "uvx",
      "args": ["mcp-server-motherduck", "--db-path", "local.duckdb", "--read-only", "--init-sql", "duckdb-init.sql"]
    }
  }
}
