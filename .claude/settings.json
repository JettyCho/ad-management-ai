{
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(curl *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(git *)",
      "Bash(cd * && git *)",
      "Bash(cd * && grep *)",
      "Bash(cd * && find *)",
      "mcp__puppeteer__*",
      "mcp__slack__*",
      "mcp__figma__*",
      "mcp__linear__*",
      "mcp__confluence__*",
      "mcp__github__*",
      "mcp__datadog__*",
      "mcp__sentry__*",
      "mcp__google_workspace__*",
      "Skill(slack-summary)",
      "Skill(slack-summary:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "puppeteer",
    "slack",
    "figma",
    "linear",
    "confluence",
    "github",
    "datadog",
    "sentry",
    "google_workspace"
  ],
  "enableAllProjectMcpServers": true,
  "alwaysThinkingEnabled": true
}
